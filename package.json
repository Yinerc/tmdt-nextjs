{
  "name": "tmdt-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:admin dev:users",
    "dev:admin": "cd admin && npm run dev",
    "dev:users": "cd users && npm run dev -- -p 3001",
    "build": "npm-run-all --parallel build:admin build:users",
    "build:admin": "cd admin && npm run build",
    "build:users": "cd users && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}